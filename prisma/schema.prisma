generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & ORGANIZATION
// ============================================

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  code               String?   @unique @db.VarChar(50)
  email              String    @unique
  fullName           String
  gender             String
  status             String    // PENDING | ACTIVE | INACTIVE
  role               String    // EMPLOYEE | DEPARTMENT_HEAD | HR | BOD
  departmentId       String    @db.Uuid
  departmentName     String?
  position           String
  contractType       String    // Intern | Trainee | Probation | Official Employee
  joinDate           DateTime?
  contractSignedDate DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("users")
}

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  code      String   @unique
  managerId String?  @db.Uuid
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("departments")
}

// ============================================
// LEAVE MANAGEMENT
// ============================================

model LeaveType {
  id                 String   @id @default(uuid()) @db.Uuid
  code               String   @unique
  name               String
  isPaid             Boolean  @default(false)
  deductCompensation Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@map("leave_types")
}

model LeaveRequest {
  id                    String          @id @default(uuid()) @db.Uuid
  leaveTypeCode         String?
  status                String          // PENDING | APPROVED | REJECTED | CANCELLED
  reason                String?
  fromDate              DateTime
  toDate                DateTime
  fromSession           String         // FULL | MORNING | AFTERNOON
  toSession             String          // FULL | MORNING | AFTERNOON
  totalDays             Float
  paidDays              Float @default(0)
  unpaidDays            Float @default(0)
  createdBy             String
  createdAt             DateTime        @default(now())
  approvedBy            String?
  approvedAt            DateTime?
  paidPersonalEventCode String?         // SELF_MARRIAGE | CHILD_MARRIAGE | FUNERAL | null
  attachmentUrl         String?
  emailSend             String?
  emailCC               String[]
  departmentId          String          @db.Uuid

  @@index([createdBy, leaveTypeCode])
  @@index([departmentId])
  @@index([createdBy])
  @@index([status])
  @@index([fromDate, toDate])
  @@map("leave_requests")
  FileUploadQueue FileUploadQueue[]
}

// ============================================
// OVERTIME MANAGEMENT
// ============================================
model OTPlan {
  id            String    @id @default(uuid()) @db.Uuid
  departmentId  String    @db.Uuid
  managerId     String    @db.Uuid
  reason        String
  status        String    @default("DRAFT") // DRAFT | PENDING | APPROVED | REJECTED
  startDate     DateTime  @db.Date
  endDate       DateTime  @db.Date
  ticketPayload Json?
  rejectedBy    String?   @db.Uuid
  rejectedAt    DateTime?
  rejectionNote String?
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tickets       OTTicket[]

  @@index([departmentId])
  @@index([managerId])
  @@index([status])
  @@map("ot_plans")
}

model OTTicket {
  id          String    @id @default(uuid()) @db.Uuid
  planId      String    @db.Uuid
  userId      String    @db.Uuid
  otType      String?    // COMPENSATION | SALARY
  workDate    DateTime  @db.Date  // ngày làm việc
  startTime   DateTime            // datetime đầy đủ
  endTime     DateTime            // datetime đầy đủ (có thể sang ngày hôm sau nếu overnight)
  totalHours  Float
  checkIn     DateTime?
  checkOut    DateTime?
  actualHours Float?
  plan        String?
  result      String?
  status      String    @default("SCHEDULED")
  verifiedBy  String?
  verifiedAt  DateTime?
  rejectNote  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  otPlan OTPlan @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([userId])
  @@index([workDate])
  @@index([status])
  @@map("ot_tickets")
}

// ============================================
// OVERTIME CONFIG
// ============================================

model OTConfig {
  id               String   @id @default(uuid()) @db.Uuid
  maxHoursPerDay   Float    @default(4)
  maxHoursPerMonth Float    @default(40)
  maxHoursPerYear  Float
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("ot_config")
}

// ============================================
// COMPENSATION BALANCE
// ============================================

model CompensationBalance {
  id        String   @id @default(uuid()) @db.Uuid
  userCode  String
  year      Int
  hours     Float    @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userCode, year])
  @@map("compensation_balances")
}

// ============================================
// HOLIDAYS
// ============================================

model Holiday {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  date              DateTime
  type              String   // FIXED | CUSTOM
  session           String   // FULL | MORNING | AFTERNOON
  isRecurring       Boolean  @default(false)
  createdBy         String   @db.Uuid
  createdAt         DateTime @default(now())
  isCompensatory    Boolean  @default(false)
  originalHolidayId String?  @db.Uuid

  @@index([isCompensatory])
  @@index([date])
  @@map("holidays")
}

// ============================================
// LEAVE CONFIG
// ============================================

model LeaveConfig {
  id                   String   @id @default(uuid()) @db.Uuid
  contractType         String   @unique
  baseDaysPerYear      Float
  bonusDaysPerCycle    Float
  bonusYearCycle       Int
  maxDaysPerRequest    Float
  minimumNoticeDays    Int
  prorateByMonth       Boolean  @default(true)
  joinDateCutoffDay    Int      @default(15)
  allowNegativeBalance Boolean  @default(false)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("leave_configs")
}

model PaidPersonalLeaveEvent {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique
  name        String
  allowedDays Float
  resetOnUse  Boolean @default(true)

  @@map("paid_personal_leave_events")
}

// ============================================
// EMAIL
// ============================================

model EmailQueue {
  id        String   @id @default(uuid())
  emailSend String?
  emailCC   String[]
  type      String
  payload   Json
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("email_queue")
}

// ============================================
// STORAGE
// ============================================

model FileUploadQueue {
  id             String       @id @default(uuid()) @db.Uuid
  leaveRequestId String       @db.Uuid
  localPath      String
  retryCount     Int          @default(0)
  createdAt      DateTime     @default(now())

  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id])

  @@map("file_upload_queues")
}