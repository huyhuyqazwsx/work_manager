generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & ORGANIZATION
// ============================================

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  code               String?   @unique @db.VarChar(50)
  email              String    @unique
  fullName           String
  gender             String
  status             String    // PENDING | ACTIVE | INACTIVE
  role               String    // EMPLOYEE | DEPARTMENT_HEAD | HR | BOD
  departmentId       String?   @db.Uuid
  position           String
  contractType       String    // Intern | Trainee | Probation | Official Employee
  joinDate           DateTime
  contractSignedDate DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("users")
}

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  code      String   @unique
  managerId String?  @db.Uuid
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("departments")
}

// ============================================
// LEAVE MANAGEMENT
// ============================================

model LeaveType {
  id                 String   @id @default(uuid()) @db.Uuid
  code               String   @unique
  name               String
  isPaid             Boolean  @default(false)
  deductCompensation Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@map("leave_types")
}

model LeaveRequest {
  id                    String    @id @default(uuid()) @db.Uuid
  leaveTypeId           String    @db.Uuid
  status                String    // DRAFT | PENDING | APPROVED | REJECTED
  reason                String?
  fromDate              DateTime
  toDate                DateTime
  totalDays             Float
  createdBy             String    @db.Uuid
  createdAt             DateTime  @default(now())
  approvedBy            String?   @db.Uuid
  approvedAt            DateTime?
  paidPersonalEventCode String?   // SELF_MARRIAGE | CHILD_MARRIAGE | FUNERAL | null

  @@index([createdBy, leaveTypeId])
  @@index([status])
  @@index([fromDate, toDate])
  @@map("leave_requests")
}

// Track usage của Paid Personal Leave theo từng event
model PaidPersonalLeaveUsage {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  eventCode      String   // SELF_MARRIAGE | CHILD_MARRIAGE | FUNERAL
  usedDays       Float
  year           Int
  leaveRequestId String   @db.Uuid

  createdAt      DateTime @default(now())

  @@index([userId, eventCode, year])
  @@map("paid_personal_leave_usages")
}

// ============================================
// OVERTIME MANAGEMENT
// ============================================

model OvertimeType {
  id             String   @id @default(uuid()) @db.Uuid
  code           String   @unique  // WEEKDAY | WEEKEND | HOLIDAY
  name           String
  isCompensation Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@map("overtime_types")
}

model OvertimeRequest {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  workDate   DateTime
  startTime  DateTime
  endTime    DateTime
  totalHours Float
  otTypeId   String    @db.Uuid
  reason     String?
  status     String    // PENDING | REJECTED | APPROVED | DRAFT
  approvedBy String?   @db.Uuid
  approvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([workDate])
  @@index([status])
  @@map("overtime_requests")
}

model CompensationBalance {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  hours     Float    @default(0)
  updatedAt DateTime @updatedAt

  @@map("compensation_balances")
}

// Lịch sử thay đổi compensation balance
model CompensationTransaction {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  hours     Float    // dương = cộng từ OT
  type      String   // EARNED | USED
  sourceId  String   @db.Uuid // overtimeRequestId hoặc leaveRequestId
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("compensation_transactions")
}

// ============================================
// ATTENDANCE
// ============================================

model Attendance {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  workDate  DateTime
  checkIn   DateTime?
  checkOut  DateTime?
  status    String    // SCHEDULED | IN_PROGRESS | COMPLETED
  plan      String?
  result    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, workDate])
  @@index([userId, workDate])
  @@map("attendances")
}

// ============================================
// HOLIDAYS
// ============================================

model Holiday {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  date              DateTime
  type              String   // FIXED | CUSTOM
  session           String   // FULL | MORNING | AFTERNOON
  isRecurring       Boolean  @default(false)
  createdBy         String   @db.Uuid
  createdAt         DateTime @default(now())
  isCompensatory    Boolean  @default(false)
  originalHolidayId String?  @db.Uuid

  @@index([isCompensatory])
  @@index([date])
  @@map("holidays")
}

// ============================================
// LEAVE & OT CONFIG
// ============================================

model LeaveConfig {
  id                   String   @id @default(uuid()) @db.Uuid
  contractType         String   @unique
  baseDaysPerYear      Float
  bonusDaysPerCycle    Float
  bonusYearCycle       Int
  maxDaysPerRequest    Float
  minimumNoticeDays    Int
  prorateByMonth       Boolean  @default(true)
  joinDateCutoffDay    Int      @default(15)
  carryOverDays        Float    @default(0)
  allowNegativeBalance Boolean  @default(false)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("leave_configs")
}

model OTConfig {
  id               String   @id @default(uuid()) @db.Uuid
  contractType     String   @unique
  maxHoursPerDay   Float
  maxHoursPerMonth Float
  maxHoursPerYear  Float
  salaryMultiplier Float    @default(1.5)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("ot_configs")
}

model PaidPersonalLeaveEvent {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique
  name        String
  allowedDays Float
  resetOnUse  Boolean @default(true)

  @@map("paid_personal_leave_events")
}